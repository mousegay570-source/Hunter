local difficulties = {
    { name = "Easy",   color = Color3.fromRGB(50, 200, 50),  folder = "EggHunt_Easy",      order = 1 },
    { name = "Medium", color = Color3.fromRGB(230, 200, 0),  folder = "EggHunt_Medium",    order = 2 },
    { name = "Hard",   color = Color3.fromRGB(50, 100, 220), folder = "EggHunt_Hard",      order = 3 },
    { name = "Streme", color = Color3.fromRGB(230, 120, 0),  folder = "EggHunt_Eggstreme", order = 4 },
}

for _, data in ipairs(difficulties) do
    local isTeleporting = false
    local thread = nil

    local Btn = Instance.new("TextButton")
    Btn.Name = data.name .. "Btn"
    Btn.Parent = ButtonContainer
    Btn.BackgroundColor3 = data.color
    Btn.Size = UDim2.new(1, 0, 0, 36)
    Btn.Font = Enum.Font.SourceSansBold
    Btn.Text = "[ " .. data.name:upper() .. " ] TELEPORT: OFF"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 14
    Btn.LayoutOrder = data.order

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 8)
    BtnCorner.Parent = Btn

    local originalColor = data.color

    local function startTeleport()
        local folder = workspace:FindFirstChild(data.folder)
        if not folder then
            warn("[EggHuntUI] Folder not found: " .. data.folder)
            isTeleporting = false
            Btn.Text = "[ " .. data.name:upper() .. " ] NOT FOUND"
            Btn.BackgroundColor3 = originalColor
            return
        end
        while isTeleporting do
            local targets = folder:GetChildren()
            for _, model in pairs(targets) do
                if not isTeleporting then break end
                if model:IsA("Model") or model:IsA("BasePart") then
                    local targetPart = model:IsA("Model") and
                        (model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")) or model
                    if targetPart then
                        local character = Players.LocalPlayer.Character
                        local hrp = character and character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            hrp.CFrame = targetPart.CFrame
                            print("[EggHuntUI] Teleporting to: " .. model.Name .. " | Difficulty: " .. data.name)
                        end
                        task.wait(2)
                    end
                end
            end
            task.wait(1)
        end
    end

    Btn.MouseButton1Click:Connect(function()
        isTeleporting = not isTeleporting
        if isTeleporting then
            Btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            Btn.Text = "[ " .. data.name:upper() .. " ] TELEPORT: ON"
            print("[EggHuntUI] Started teleport | Difficulty: " .. data.name)
            thread = task.spawn(startTeleport)
        else
            Btn.BackgroundColor3 = originalColor
            Btn.Text = "[ " .. data.name:upper() .. " ] TELEPORT: OFF"
            print("[EggHuntUI] Stopped teleport | Difficulty: " .. data.name)
            if thread then task.cancel(thread) thread = nil end
        end
    end)
end

