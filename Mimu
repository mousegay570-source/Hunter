local creditsOpen = false

SeeMoreBtn.MouseButton1Click:Connect(function()
    creditsOpen = not creditsOpen
    if creditsOpen then
        SeeMoreBtn.Text = "hide credits"
        print("[EggHuntUI] Credits panel opened")
        TweenService:Create(Frame, TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 300, 0, 400)
        }):Play()
    else
        SeeMoreBtn.Text = "see more credits"
        print("[EggHuntUI] Credits panel closed")
        TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 300, 0, 280)
        }):Play()
    end
end)

local isMinimized = false

MinimizeBtn.MouseButton1Click:Connect(function()
    isMinimized = not isMinimized
    if isMinimized then
        if creditsOpen then
            creditsOpen = false
            SeeMoreBtn.Text = "see more credits"
        end
        MinimizeBtn.Text = "+"
        ContentFrame.Visible = false
        print("[EggHuntUI] UI minimized")
        TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 300, 0, 38)
        }):Play()
    else
        MinimizeBtn.Text = "-"
        print("[EggHuntUI] UI restored")
        TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 300, 0, 280)
        }):Play()
        task.delay(0.3, function()
            ContentFrame.Visible = true
        end)
    end
end)

